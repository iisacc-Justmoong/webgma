{
  "name": "Webgma",
  "version": "1.0.0",
  "description": "Figma plugin scaffold for static HTML/CSS analysis and Figma design generation.",
  "type": "module",
  "scripts": {
    "clean": "rm -rf build",
    "build": "npm run clean && npm run build:plugin",
    "build:plugin": "node scripts/build-plugin.mjs",
    "prepare:release": "npm run build && node scripts/prepare-release.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "node-html-parser": "^7.0.1"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.113.0",
    "@types/node": "^24.6.1",
    "esbuild": "^0.25.10",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "private": true
}
